# ============================================================
# Data Files — keep gene_lists/ CSVs but ignore raw data
# ============================================================

# Raw count data (TSV uploads) — do not commit large sequencing files
*.tsv
*.bam
*.sam
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bed
*.gtf
*.gff
*.gff3

# Ignore all CSVs globally except those in gene_lists/
*.csv
!gene_lists/*.csv
!gene_lists/**/*.csv

# Output/results directories
results/
outputs/
figures/
plots/

